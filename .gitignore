## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio cache/options directory
.vs/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# Others
*.cache
*.log
*.vsidx
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Node.js (if using Angular)
node_modules/
npm-debug.log
yarn-error.log

# Angular
dist/
tmp/
out-tsc/
.angular/

# Sensitive configuration files (user settings)
appsettings.json
appsettings.*.json
!appsettings.example.json
!appsettings.example.Development.json

# Environment files
.env
.env.local
.env.*.local
