{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "POSConnection": "Data Source=YOUR_SERVER\\SQLEXPRESS;Database=POS;User Id=sa;Password=YOUR_PASSWORD;",
    "AzureStorage": "DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net"
  },
  "Jwt": {
    "Issuer": "https://your-domain.com/",
    "Secret": "YOUR_JWT_SECRET_KEY_HERE_MINIMUM_256_CHARACTERS_REQUIRED_FOR_SECURITY",
    "Expires": "8"
  }
}
